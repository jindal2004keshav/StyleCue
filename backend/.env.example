# Anthropic
ANTHROPIC_API_KEY=

# Anthropic Models
ANTHROPIC_ANALYST_MODEL=claude-sonnet-4-6
ANTHROPIC_RESPONSE_MODEL=claude-sonnet-4-6

# Gemini
GEMINI_API_KEY=
GEMINI_ANALYST_MODEL=gemini-3.1
GEMINI_RESPONSE_MODEL=gemini-3.1

# Fallback Models (used only if provider-specific values are absent)
ANALYST_MODEL=claude-sonnet-4-6
RESPONSE_MODEL=claude-sonnet-4-6

# BrandEye
BRANDEYE_SEARCH_HOST=https://ai-search-brandeye.blr.streamoid.com

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173","null"]
UPLOADS_DIR=uploads
